msgstr "Use select_related() para fazer JOIN com a tabela de autores em uma única query."

msgid "N+1 Query - ManyToMany"
msgstr "N+1 Query - ManyToMany"

msgid "When iterating over books and accessing their tags, each access triggers a separate query."
msgstr "Ao iterar sobre livros e acessar suas tags, cada acesso gera uma query separada."

msgid "Book.objects.all() - WITHOUT prefetch_related"
msgstr "Book.objects.all() - SEM prefetch_related"

msgid "Book.objects.prefetch_related(\"tags\") - WITH prefetch_related"
msgstr "Book.objects.prefetch_related(\"tags\") - COM prefetch_related"

msgid "Use prefetch_related() to fetch all tags in a separate query (2 queries total)."
msgstr "Use prefetch_related() para buscar todas as tags em uma query separada (2 queries total)."


msgid "Loading all database fields, including heavy fields like TextField, even when not needed."
msgstr "Carregar todos os campos do banco, incluindo campos pesados como TextField, mesmo quando não necessários."

msgid "Book.objects.all() - loads ALL fields"
msgstr "Book.objects.all() - carrega TODOS os campos"

msgid "Book.objects.only(\"title\", \"price\") - loads ONLY the needed fields"
msgstr "Book.objects.only(\"title\", \"price\") - carrega APENAS os campos necessários"

msgid "Use only() to specify which fields you need, or defer() to exclude unnecessary fields."
msgstr "Use only() para especificar quais campos você precisa, ou defer() para excluir campos desnecessários."

msgid "Using len() on a QuerySet forces evaluation of ALL records just to count in Python."
msgstr "Usar len() em um QuerySet força a avaliação de TODOS os registros para contar em Python."

msgid "len(Book.objects.all()) - LOADS all records into memory"
msgstr "len(Book.objects.all()) - CARREGA todos os registros na memória"

msgid "Book.objects.count() - uses COUNT(*) in the database"
msgstr "Book.objects.count() - usa COUNT(*) no banco de dados"

msgid "Use .count() which executes SELECT COUNT(*) in the database, much more efficient."
msgstr "Use .count() que executa SELECT COUNT(*) no banco, muito mais eficiente."

msgid "Loading all records at once into memory causes slowness and high memory consumption."
msgstr "Carregar todos os registros de uma vez na memória causa lentidão e alto consumo de memória."

msgid "Book.objects.all()[:200] - loads everything at once"
msgstr "Book.objects.all()[:200] - carrega tudo de uma vez"

msgid "Paginator(qs, per_page=20) - loads only one page"
msgstr "Paginator(qs, per_page=20) - carrega apenas uma página"

msgid "Use Django Paginator to load only the necessary records per page."
msgstr "Use Paginator do Django para carregar apenas os registros necessários por página."

